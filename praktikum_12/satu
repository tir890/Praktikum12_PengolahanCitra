import os
import cv2
import matplotlib.pyplot as plt
import numpy as np

# 1. Deteksi folder skrip
BASE_DIR = os.path.dirname(os.path.abspath(__file__))

# 2. Definisikan nama file (UBAH .jpg di bawah ini jika aslinya .png/.jpeg/.webp)
nama_foto1 = "kereta1.jpeg" 
nama_foto2 = "kereta2.jpg"

path_query = os.path.join(BASE_DIR, nama_foto1)
path_train = os.path.join(BASE_DIR, nama_foto2)

# 3. Gunakan plt.imread (Lebih ramah terhadap path Windows dibanding cv2.imread)
try:
    # plt.imread membaca dalam format RGB
    query_img_rgb = plt.imread(path_query)
    train_img_rgb = plt.imread(path_train)
    
    # Ubah ke format BGR agar sesuai dengan standar OpenCV di sisa kode
    query_img = cv2.cvtColor(query_img_rgb, cv2.COLOR_RGB2BGR)
    train_img = cv2.cvtColor(train_img_rgb, cv2.COLOR_RGB2BGR)
    
    print("-> Gambar BERHASIL dimuat!")

    # 4. Proses konversi ke skala abu-abu (Grayscale)
    query_img_bw = cv2.cvtColor(query_img, cv2.COLOR_BGR2GRAY)
    train_img_bw = cv2.cvtColor(train_img, cv2.COLOR_BGR2GRAY)

    # 5. Inisialisasi detektor ORB
    orb = cv2.ORB_create()

    # Mendeteksi Titik Kunci (Keypoints) dan Deskriptor
    queryKeypoints, queryDescriptors = orb.detectAndCompute(query_img_bw, None)
    trainKeypoints, trainDescriptors = orb.detectAndCompute(train_img_bw, None)

    # Mencocokkan Deskriptor menggunakan Brute-Force Matcher
    matcher = cv2.BFMatcher()
    matches = matcher.match(queryDescriptors, trainDescriptors)

    # Memvisualisasikan 20 kecocokan terbaik
    final_img = cv2.drawMatches(
        query_img, queryKeypoints, train_img, trainKeypoints, matches[:20], None
    )
    final_img = cv2.resize(final_img, (1000, 650))

    # Menampilkan hasil gambar
    plt.figure(figsize=(10, 6))
    plt.imshow(cv2.cvtColor(final_img, cv2.COLOR_BGR2RGB))
    plt.title("Feature Matches - Kereta")
    plt.axis("off")
    plt.show()

except FileNotFoundError as e:
    print(f"\n[ERROR BARU] File benar-benar tidak ada di folder.")
    print(f"Pastikan di folder 'praktikum_12' ada file bernama: {nama_foto1} dan {nama_foto2}")
except Exception as e:
    print(f"\n[ERROR LAIN]: {e}")
    print("Kemungkinan besar ekstensi file salah (misal: aslinya .png atau .jpeg tapi ditulis .jpg)")